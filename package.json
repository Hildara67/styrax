{
  "name": "sistema-riego",
  "version": "1.0.0",
  "description": "Sistema Inteligente de Control de Riego - Fase 4 Implementación",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --exec electron .",
    "build": "electron-builder --win",
    "docs": "jsdoc src -d docs/jsdoc",
    "demo": "node server.js",
    "start:web": "node server.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "electron": "^28.0.0",
    "express": "^5.2.1",
    "mysql2": "^3.6.0"
  },
  "devDependencies": {
    "electron-builder": "^24.9.1",
    "jsdoc": "^4.0.2",
    "nodemon": "^3.0.2"
  },
  "build": {
    "appId": "com.riego.sistema",
    "productName": "Sistema Riego",
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
